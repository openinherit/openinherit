{
  "_disclaimer": "This file defines the multi-agent task protocol for INHERIT. Agent implementations should consume these definitions to understand their inputs, outputs, and applicable platforms. This is reference data — the schema files in v1/ are the source of truth for field definitions.",
  "tasks": {
    "find_comparables": {
      "description": "Search marketplaces for items comparable to the input asset. Uses brand, model, category, subcategory, and comparableSearchProfile to construct searches. Returns a ranked list of comparable listings with prices, condition notes, and source URLs.",
      "inputFields": [
        "id",
        "name",
        "brand",
        "model",
        "category",
        "subcategory",
        "condition",
        "searchTerms",
        "comparableSearchProfile",
        "images"
      ],
      "outputFields": [
        "comparables",
        "searchTerms",
        "comparableSearchProfile.lastSearchedAt",
        "comparableSearchProfile.searchCount"
      ],
      "applicablePlatforms": [
        "ebay",
        "catawiki",
        "amazon",
        "worthpoint",
        "liveauctioneers",
        "specialist_dealers"
      ],
      "applicableCategories": [
        "collectibles",
        "jewellery",
        "art",
        "antiques",
        "vehicles",
        "electronics",
        "firearms_sporting",
        "watches_clocks",
        "wine_spirits",
        "coins_medals"
      ]
    },
    "estimate_value": {
      "description": "Produce an AI-generated valuation for the asset based on comparable listings previously gathered. Synthesises comparables, condition, provenance, and market trends into a low/mid/high estimate range with a recommended insurance value.",
      "inputFields": [
        "id",
        "name",
        "brand",
        "model",
        "category",
        "subcategory",
        "condition",
        "provenance",
        "comparables",
        "comparableSearchProfile",
        "valuations",
        "images"
      ],
      "outputFields": [
        "valuations",
        "valuations[].estimatedValue",
        "valuations[].valuationRangeLow",
        "valuations[].valuationRangeHigh",
        "valuations[].valuationBasis",
        "valuations[].confidence",
        "valuations[].valuedAt",
        "valuations[].valuedBy",
        "valuations[].notes"
      ],
      "applicablePlatforms": [
        "anthropic_claude",
        "openai_gpt4",
        "internal_valuation_model"
      ],
      "applicableCategories": [
        "collectibles",
        "jewellery",
        "art",
        "antiques",
        "vehicles",
        "electronics",
        "firearms_sporting",
        "watches_clocks",
        "wine_spirits",
