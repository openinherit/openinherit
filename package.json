{
  "name": "openinherit",
  "version": "1.1.0",
  "private": true,
  "description": "INHERIT — open estate data interchange standard",
  "type": "module",
  "scripts": {
    "validate": "node scripts/validate-schemas.mjs",
    "lint:openapi": "npx @redocly/cli lint openapi/v1/openapi.yaml",
    "test": "node scripts/run-tests.mjs",
    "generate": "npx @hey-api/openapi-ts -i openapi/v1/openapi-bundled.yaml -o generated/typescript -c @hey-api/client-fetch",
    "bundle": "npx @redocly/cli bundle openapi/v1/openapi.yaml -o openapi/v1/openapi-bundled.yaml",
    "lint:reference-api": "npx @redocly/cli lint openapi/v1/reference-api.yaml",
    "bundle:reference-api": "npx @redocly/cli bundle openapi/v1/reference-api.yaml -o openapi/v1/reference-api-bundled.yaml",
    "generate:reference-api": "npx @hey-api/openapi-ts -i openapi/v1/reference-api-bundled.yaml -o generated/typescript-api -c @hey-api/client-fetch",
    "build": "pnpm --filter @openinherit/sdk run build",
    "build:sdk": "pnpm --filter @openinherit/sdk run build",
    "clean": "pnpm --filter @openinherit/sdk run clean",
    "lint:schema": "jsonschema lint v1/*.json v1/common/*.json --resolve v1/dialect.json --resolve v1/common/ --resolve v1/ --exclude top_level_examples --exclude simple_properties_identifiers",
    "fmt:schema": "jsonschema fmt --check --keep-ordering v1/*.json v1/common/*.json",
    "metaschema": "jsonschema metaschema v1/*.json v1/common/*.json --resolve v1/dialect.json --resolve v1/common/"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "latest",
    "@hey-api/client-fetch": "latest",
    "@redocly/cli": "latest",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  },
  "license": "Apache-2.0"
}
