[
  {
    "description": "common/money schema",
    "schema": { "$ref": "https://openinherit.org/v1/common/money.json" },
    "tests": [
      {
        "description": "valid money with integer amount and ISO 4217 currency",
        "data": { "amount": 32500, "currency": "GBP" },
        "valid": true
      },
      {
        "description": "valid zero amount",
        "data": { "amount": 0, "currency": "USD" },
        "valid": true
      },
      {
        "description": "valid negative amount (debts)",
        "data": { "amount": -15000, "currency": "EUR" },
        "valid": true
      },
      {
        "description": "valid Japanese Yen",
        "data": { "amount": 1000000, "currency": "JPY" },
        "valid": true
      },
      {
        "description": "invalid — float amount",
        "data": { "amount": 325.50, "currency": "GBP" },
        "valid": false
      },
      {
        "description": "invalid — missing currency",
        "data": { "amount": 1000 },
        "valid": false
      },
      {
        "description": "invalid — missing amount",
        "data": { "currency": "GBP" },
        "valid": false
      },
      {
        "description": "invalid — lowercase currency code",
        "data": { "amount": 1000, "currency": "gbp" },
        "valid": false
      },
      {
        "description": "invalid — two-letter currency code",
        "data": { "amount": 1000, "currency": "GB" },
        "valid": false
      }
    ]
  }
]
