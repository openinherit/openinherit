      "data": {
        "value": "AB123456C"
      },
      "valid": true
    },
    {
      "description": "valid — UK National Insurance number with system and type",
      "data": {
        "system": "urn:hmrc:nino",
        "value": "AB123456C",
        "type": "national_insurance"
      },
      "valid": true
    },
    {
      "description": "valid — Japanese My Number identifier",
      "data": {
        "system": "urn:jpn:my-number",
        "value": "1234 5678 9012",
        "type": "national_id"
      },
      "valid": true
    },
    {
      "description": "valid — Indian Aadhaar number",
      "data": {
        "system": "urn:uidai:aadhaar",
        "value": "1234 5678 9012",
        "type": "national_id"
      },
      "valid": true
    },
    {
      "description": "valid — US Social Security Number",
      "data": {
        "system": "urn:ssa:ssn",
        "value": "123-45-6789",
